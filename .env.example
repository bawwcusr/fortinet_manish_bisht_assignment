# Each service reads DATABASE_URL (async driver) and ALEMBIC_DATABASE_URL (sync driver).
# Values below use localhost — same URLs for Docker Compose, local dev, curl, and Postman.
# Postgres is published on localhost:5432 from docker-compose.

# --- Scheduler service ---
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/scheduler_db
ALEMBIC_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/scheduler_db
LOG_LEVEL=INFO
MAX_RETRIES=3
BACKOFF_BASE_SECONDS=1.0
BACKOFF_MAX_SECONDS=60.0
HTTP_TIMEOUT_SECONDS=10.0
POLL_MAX_ATTEMPTS=10
POLL_INTERVAL_SECONDS=5.0
SCHEDULER_MISFIRE_GRACE_SECONDS=30
EXECUTOR_BASE_URL=http://localhost:8081
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

# --- Executor service ---
# DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/executor_db
# ALEMBIC_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/executor_db
# ASYNC_DELAY_SECONDS=5.0   # simulated downstream business-logic runtime (async)
# SYNC_DELAY_SECONDS=5.0    # simulated downstream business-logic runtime (sync)
# ASYNC_MAX_IN_FLIGHT=32
# FAIL_ENDPOINTS=
